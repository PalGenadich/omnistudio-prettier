# Dev-only packages (not needed at runtime)
node_modules/esbuild/**
node_modules/@esbuild/**
node_modules/@types/**
node_modules/omnistudio-formatter/**

# Unnecessary file types inside node_modules
node_modules/**/*.d.ts
node_modules/**/*.d.ts.map
node_modules/**/*.map
node_modules/**/.bin

# Test files inside packages
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/__tests__/**
node_modules/**/spec/**
node_modules/**/__mocks__/**

# Source files (only transpiled output is needed)
omnistudio-formatter/**
extension.js
build.js
.vscode/**
.gitignore
.prettierrc
settings.local.json
